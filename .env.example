# Azure Blob Storage - event images
# Public container for caller reads. Event writes and image upload/delete happen server-side via /api/events.
# Create once:
#   az storage container create --account-name personaldatabasen --name event-images --public-access blob

# Server-side only
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_ACCOUNT_NAME=personaldatabasen
AZURE_BLOB_ACCOUNT_KEY=
AZURE_EVENT_IMAGES_CONTAINER=event-images
AZURE_EVENT_IMAGES_PUBLIC_URL=https://personaldatabasen.blob.core.windows.net/event-images
